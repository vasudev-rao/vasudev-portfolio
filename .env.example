# Copy this file to .env.local and fill in your values
# .env.local is gitignored and safe for secrets

# Your deployed domain — used for SEO canonical URLs and OG tags
NEXT_PUBLIC_SITE_URL=https://vasudevarao.com

# Google Search Console verification (optional)
# Get from: https://search.google.com/search-console
NEXT_PUBLIC_GOOGLE_VERIFICATION=your-verification-code-here

# Google Analytics (optional)
# Get from: https://analytics.google.com
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
